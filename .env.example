# ─────────────────────────────────────────────
#  AL-SHIFAH CHARITY FOUNDATION — Environment
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
DB_HOST=localhost
DB_NAME=al_shifah_db
DB_USER=root
DB_PASS=

# ── Application ───────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/AL-SHIFAH-CHARITY-FOUNDATION

# ── Paystack ──────────────────────────────────
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here

# ── Mail (optional — for contact form) ────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM_ADDRESS=noreply@alshifah.org
MAIL_FROM_NAME=Al-Shifah Charity Foundation
